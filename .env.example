# new-pawnshop-backend environment variables
# Copy to .env for local dev. On Render, set these in the dashboard (or via render.yaml).

# development | production
NODE_ENV=production

# Render provides PORT automatically; only set locally.
PORT=8888

# MongoDB Atlas connection string (free M0 tier). Percent-encode special chars in the password.
MONGODB_URI=mongodb+srv://user:pass@cluster0.xxxx.mongodb.net/?appName=Cluster0

# Long random secret for signing JWTs.
JWT_SECRET=replace-with-a-long-random-secret

# Shared service token. MUST match AUCTION_ADMIN_TOKEN in the admin panel.
AUCTION_ADMIN_TOKEN=replace-with-a-strong-shared-token

# Exact allowed browser origins (comma separated), e.g. your Vercel production domains.
CORS_ORIGINS=https://your-front.vercel.app,https://your-admin.vercel.app

# Allow any https://*.vercel.app origin (handy for Vercel preview deployments).
CORS_ALLOW_VERCEL_PREVIEWS=true

# Allow any https://*.onrender.com origin.
CORS_ALLOW_RENDER_PREVIEWS=false

# Allow http://localhost origins. Defaults to true in development, false in production.
# CORS_ALLOW_LOCALHOST=false

# Serve Swagger docs at /docs and /openapi.json. Keep off in production.
ENABLE_API_DOCS=false

# Storefront base URL (used for links); optional.
FRONTEND_BASE_URL=https://your-front.vercel.app

# Payments are intentionally disabled for now (Stripe is a stub).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Minutes an unpaid order holds reserved stock before auto-release (min 5, default 30).
RESERVATION_WINDOW_MINUTES=30

# Order confirmation email (SMTP). Leave SMTP_HOST empty to disable emails (safe no-op).
# Free options that work out of the box with these vars:
#   Brevo (recommended, 300 emails/day free): SMTP_HOST=smtp-relay.brevo.com,
#     SMTP_PORT=587, SMTP_SECURE=false, SMTP_USER=<brevo login>, SMTP_PASS=<brevo SMTP key>.
#     Verify a sender address in Brevo and use it in SMTP_FROM.
#   Gmail (free, ~500/day): SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_SECURE=false,
#     SMTP_USER=<you>@gmail.com, SMTP_PASS=<Google App Password> (needs 2FA enabled).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Nowy Lombard <no-reply@nowylombard.pl>
